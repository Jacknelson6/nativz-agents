{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nativz Agents",
  "version": "3.0.0",
  "identifier": "com.nativz.agents",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build && cd agent-runtime && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nativz Agents",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../agents/**/*",
      "../agent-runtime/package.json",
      "../agent-runtime/dist/index.mjs",
      "../agent-runtime/src/**/*",
      "../agent-runtime/node_modules/better-sqlite3/**/*",
      "../agent-runtime/node_modules/bindings/**/*",
      "../agent-runtime/node_modules/file-uri-to-path/**/*",
      "../agent-runtime/node_modules/prebuild-install/**/*"
    ]
  }
}